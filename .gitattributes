###############################################################################
# Ocypus Nexus Git Attributes
###############################################################################

* text=auto eol=lf

###############################################################################
# Source Code
###############################################################################

*.py      text eol=lf
*.sql     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf

*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf

*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf

*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

*.sh      text eol=lf

###############################################################################
# Windows Scripts
###############################################################################

*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

###############################################################################
# Binary Files
###############################################################################

*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary

*.pdf     binary
*.zip     binary
*.7z      binary
*.rar     binary

*.xlsx    binary
*.xls     binary
*.docx    binary
*.pptx    binary

*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary

###############################################################################
# Database
###############################################################################

*.db      binary
*.sqlite  binary
*.sqlite3 binary

###############################################################################
# Git Merge
###############################################################################

package-lock.json merge=union
pnpm-lock.yaml merge=union
