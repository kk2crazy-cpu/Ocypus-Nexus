# ==================================================
# Ocypus Nexus EditorConfig
# https://editorconfig.org
# ==================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.{css,scss,less}]
indent_size = 2

[*.html]
indent_size = 2

[*.py]
indent_size = 4

[*.sql]
indent_size = 4

[*.sh]
indent_size = 2

[Dockerfile]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf
