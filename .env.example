###############################################################################
# Application
###############################################################################

APP_NAME=Ocypus Nexus
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True

###############################################################################
# Database
###############################################################################

DATABASE_TYPE=sqlite

SQLITE_PATH=database/ocypus_nexus.db

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=ocypus_nexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

###############################################################################
# Security
###############################################################################

SECRET_KEY=CHANGE_THIS_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

###############################################################################
# Redis (Future)
###############################################################################

REDIS_HOST=localhost
REDIS_PORT=6379

###############################################################################
# Upload
###############################################################################

UPLOAD_PATH=storage/uploads
MAX_UPLOAD_SIZE_MB=100

###############################################################################
# Export
###############################################################################

EXPORT_PATH=storage/exports

###############################################################################
# Log
###############################################################################

LOG_LEVEL=INFO

###############################################################################
# Timezone
###############################################################################

TIMEZONE=Asia/Taipei

###############################################################################
# CORS
###############################################################################

CORS_ALLOW_ORIGINS=http://localhost:5173

###############################################################################
# Docker
###############################################################################

DOCKER_PROJECT_NAME=ocypus-nexus
